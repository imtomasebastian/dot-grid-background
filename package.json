{
  "name": "dot-grid-background",
  "version": "0.2.0",
  "description": "Interactive animated dot-grid canvas background — cursor push/glow, click ripples, organic drift. Framework-agnostic core + React wrapper.",
  "type": "module",
  "license": "MIT",
  "author": "Tomas Sebastian",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/imtomasebastian/dot-grid-background.git"
  },
  "homepage": "https://github.com/imtomasebastian/dot-grid-background#readme",
  "bugs": {
    "url": "https://github.com/imtomasebastian/dot-grid-background/issues"
  },
  "keywords": ["canvas", "background", "animation", "react", "dot-grid"],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./core": {
      "types": "./dist/core.d.ts",
      "import": "./dist/core.js",
      "require": "./dist/core.cjs"
    }
  },
  "files": ["dist"],
  "sideEffects": false,
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "build:lib": "tsup",
    "prepare": "tsup"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "peerDependenciesMeta": {
    "react": { "optional": true },
    "react-dom": { "optional": true }
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.5.2",
    "dialkit": "^1.3.0",
    "motion": "^12.42.1",
    "tsup": "^8.5.1",
    "typescript": "~5.8.3",
    "vite": "^6.3.5"
  },
  "allowScripts": {
    "esbuild@0.27.7": true,
    "fsevents@2.3.3": true
  }
}
